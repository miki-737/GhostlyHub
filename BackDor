--// 👻 GHOSTLYHUB SERVER SCRIPT
--// Va en ServerScriptService del juego

local ReplicatedStorage = game:GetService("ReplicatedStorage")

-- Crear el RemoteEvent si no existe
local remote = ReplicatedStorage:FindFirstChild("GhostlyHubRemote")
if not remote then
    remote = Instance.new("RemoteEvent")
    remote.Name = "GhostlyHubRemote"
    remote.Parent = ReplicatedStorage
end

-- Crear carpeta de herramientas si no existe
local toolsFolder = ReplicatedStorage:FindFirstChild("Tools")
if not toolsFolder then
    toolsFolder = Instance.new("Folder")
    toolsFolder.Name = "Tools"
    toolsFolder.Parent = ReplicatedStorage
end

remote.OnServerEvent:Connect(function(player, action, toolName, amount)
    -- Verificación de seguridad básica
    if typeof(action) ~= "string" then return end
    if action ~= "give" then return end
    
    -- Buscar la herramienta
    local tool = toolsFolder:FindFirstChild(toolName)
    if not tool then 
        warn("Herramienta no encontrada: " .. tostring(toolName))
        return 
    end
    
    -- Limitar cantidad (anti-lag)
    amount = math.clamp(tonumber(amount) or 1, 1, 50)
    
    -- Dar las herramientas
    for i = 1, amount do
        local clone = tool:Clone()
        clone.Parent = player.Backpack
    end
    
    print(string.format("GhostlyHub: %s recibió %d %s", player.Name, amount, toolName))
end)

print("GhostlyHub Server cargado correctamente")
